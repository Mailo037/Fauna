{
  "name": "fauna-desktop",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "description": "Fauna desktop app shell",
  "main": "electron/main.js",
  "scripts": {
    "desktop": "electron .",
    "desktop:build": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "ai.fauna.desktop",
    "productName": "Fauna",
    "asar": true,
    "files": [
      "index.html",
      "desktop-quick.html",
      "app-shell.js",
      "script.js",
      "styles.css",
      "components/**/*",
      "modules/**/*",
      "scripts/**/*",
      "styles/**/*",
      "favicon.png",
      "favicon.svg",
      "build/icon.ico",
      "version.json",
      "local-bridge.py",
      "LICENSE",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "Mailo037",
        "repo": "Fauna"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    }
  }
}
