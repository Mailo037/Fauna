{
  "name": "fauna-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Fauna desktop app shell",
  "main": "electron/main.js",
  "scripts": {
    "desktop": "electron .",
    "desktop:build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "ai.fauna.desktop",
    "productName": "Fauna",
    "asar": true,
    "files": [
      "index.html",
      "app-shell.js",
      "script.js",
      "styles.css",
      "components/**/*",
      "modules/**/*",
      "scripts/**/*",
      "styles/**/*",
      "favicon.png",
      "favicon.svg",
      "local-bridge.py",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    }
  }
}
